# Arch3 — variáveis de ambiente (Node/Express no Render)
# Copie para `.env` localmente e preencha. NUNCA versione o .env.
# No Render, defina estas variáveis no painel (Environment) ou via render.yaml.

# Chave da OpenAI (obrigatória para gerar imagem)
OPENAI_API_KEY=sk-...

# E-mail do administrador: quem logar com ele acessa /admin e a lista de leads.
ADMIN_EMAIL=gutecla@gmail.com

# Segredo para assinar o cookie de sessão (qualquer string longa aleatória).
SESSION_SECRET=troque-por-uma-string-longa-aleatoria

# Modelo / tamanho / qualidade da imagem (opcionais — padrões abaixo).
# A OpenAI só aceita 1024x1024, 1536x1024, 1024x1536 ou auto.
OPENAI_IMAGE_MODEL=gpt-image-1.5
OPENAI_IMAGE_SIZE=1536x1024
# low | medium | high.  medium ~= $0.05/geracao | high ~= $0.20 | low ~= $0.013
OPENAI_IMAGE_QUALITY=medium
# Qualidade usada por assinantes Pro
OPENAI_IMAGE_QUALITY_PRO=high

# Pasta de dados (users/leads/geracoes em JSON). Padrao: ./data
# No Render free o disco e efemero; para persistir use um Render Disk em /var/data.
DATA_DIR=./data

# Porta (opcional — o Render injeta PORT automaticamente)
PORT=3000
