# Arch3 — backend environment
# Copie este arquivo para `.env` e preencha os valores.
# O .env NUNCA deve ir para o controle de versão nem ser exposto no frontend.

# Chave da OpenAI (obrigatória para POST /api/generate)
OPENAI_API_KEY=sk-...

# Provider de geração de imagem (opcional — padrão: openai)
# Futuro: stability | flux | replicate (ver src/services/imageGeneration/)
IMAGE_PROVIDER=openai

# Modelo de imagem usado em images.edit (opcional — padrão abaixo)
OPENAI_IMAGE_MODEL=gpt-image-1.5

# Tamanho pedido à OpenAI (opcional). A API só aceita 1024x1024, 1536x1024,
# 1024x1536 ou auto. Usamos o mais largo e expandimos para panorama 2:1 depois.
OPENAI_IMAGE_SIZE=1536x1024

# Qualidade da imagem (opcional): low | medium | high.
# high ≈ $0.20/geração (1536x1024) · medium ≈ $0.05 · low ≈ $0.013.
OPENAI_IMAGE_QUALITY=high

# Estratégia de expansão para panorama 2:1 (opcional — padrão: ambient).
# Futuro: outpaint-openai | stability | replicate | panorama-native
PANORAMA_EXPANSION=ambient

# Porta do servidor Express (opcional — padrão 3000)
PORT=3000
